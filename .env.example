# API
DATABASE_URL=postgresql://postgres:password@localhost:5432/actober
REDIS_URL=redis://localhost:6379
OPENAI_API_KEY=sk-...
NODE_ENV=development
PORT=3001
SENTRY_DSN=https://...@sentry.io/...

# Rate limiting (requests per minute — defaults shown)
API_RATE_LIMIT=100
CHAT_RATE_LIMIT=20
TRANSCRIBE_RATE_LIMIT=10

# CORS — comma-separated origins for production (leave blank to allow all)
CORS_ORIGINS=

# Mobile
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
EXPO_PUBLIC_ENV=development
