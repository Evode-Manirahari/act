generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String          @id @default(uuid())
  deviceId            String          @unique
  name                String?
  experienceLevel     ExperienceLevel @default(BEGINNER)
  subscriptionTier    SubscriptionTier @default(FREE)
  subscriptionExpiry  DateTime?
  projectsThisMonth   Int             @default(0)
  monthResetAt        DateTime        @default(now())
  createdAt           DateTime        @default(now())
  sessions            Session[]
  projects            Project[]
}

model Session {
  id        String              @id @default(uuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id])
  projectId String?
  project   Project?            @relation(fields: [projectId], references: [id])
  phase     ConversationPhase   @default(DISCOVERY)
  messages  Message[]
  createdAt DateTime            @default(now())
}

model Message {
  id        String      @id @default(uuid())
  sessionId String
  session   Session     @relation(fields: [sessionId], references: [id])
  role      MessageRole
  content   String
  createdAt DateTime    @default(now())
}

model Project {
  id               String          @id @default(uuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id])
  title            String
  description      String
  category         ProjectCategory
  status           ProjectStatus   @default(SUGGESTED)
  materials        String[]
  timeRequired     Int
  currentStepIndex Int             @default(0)
  contextSnapshot  String
  steps            Step[]
  sessions         Session[]
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime        @default(now())
}

model Step {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  order       Int
  title       String
  description String
  completed   Boolean  @default(false)

  @@unique([projectId, order])
}

enum SubscriptionTier {
  FREE
  PLUS
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  EXPERIENCED
}

enum ProjectCategory {
  MAKE
  IMPROVE
  GROW
  CREATE
}

enum ProjectStatus {
  SUGGESTED
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum MessageRole {
  USER
  ASSISTANT
}

enum ConversationPhase {
  DISCOVERY
  SUGGESTION
  COACHING
  COMPLETE
}
