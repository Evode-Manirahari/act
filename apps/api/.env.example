# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/act_db
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...          # Used for Whisper speech-to-text transcription

# ── Server ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3002

# ── Cache ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379    # Required for rate limiting

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins in production
# ALLOWED_ORIGINS=https://actguidance.app,https://api.actguidance.app

# ── Optional ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
