# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/actober
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Server ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3002

# ── CORS ───────────────────────────────────────────────────────────────────────
