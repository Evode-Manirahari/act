# Shared-password gate for the whole admin app (middleware.ts). Unset = dev
# mode, no gate. Production deploys MUST set it.
ADMIN_PASSWORD=

# act-api base URL. Defaults to the deployed Fly backend if unset.
NEXT_PUBLIC_ACT_API_BASE_URL=https://act-api-evode.fly.dev

# Supabase service login for act-api calls (pilot auth Phase 4, lib/actAuth.ts).
# All four must be set together; any unset = the admin talks to act-api
# anonymously (fine until the backend sets AUTH_REQUIRED). Provision the
# admin's Supabase user AND its act-api `users` row with the same email.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
ADMIN_SUPABASE_EMAIL=
ADMIN_SUPABASE_PASSWORD=
