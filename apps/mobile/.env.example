# API base URL — no trailing slash. Read by src/lib/config.ts; falls back to
# the deployed Fly backend if unset, so this only needs setting for local dev.
# Local backend (act-api running with `uvicorn` on this machine): http://localhost:8080
# Deployed pilot backend (default if unset): https://act-api-evode.fly.dev
EXPO_PUBLIC_API_BASE_URL=https://act-api-evode.fly.dev

# Supabase (invite-only pilot auth). Leave unset for local/demo dev — the app
# falls back to the existing demo-session flow until both of these are set.
# The publishable key is safe to embed in a mobile client (Supabase's
# anon/publishable key, not a service-role secret).
EXPO_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
