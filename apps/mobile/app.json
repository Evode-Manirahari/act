{
  "expo": {
    "name": "ACT",
    "slug": "act-guidance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#0A0A0A",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF8"
    },
    "plugins": [
      "expo-camera",
      "expo-av",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#F97316",
          "sounds": [],
          "iosDisplayInForeground": true
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.actguidance.app",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "ACT sends you a daily reminder to work on a hands-on project.",
        "NSCameraUsageDescription": "ACT uses your camera to see what you're working on and give accurate guidance.",
        "NSMicrophoneUsageDescription": "ACT uses your microphone so you can describe the job by speaking.",
        "NSPhotoLibraryUsageDescription": "ACT can read photos from your library to help diagnose the job."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F97316"
      },
      "package": "com.actguidance.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
