{
  "expo": {
    "name": "ACT",
    "slug": "act-guidance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#0A0A0A",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF8"
    },
    "plugins": [
      "expo-camera",
      "expo-av",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#EA580C",
          "sounds": [],
          "iosDisplayInForeground": true
        }
      ],
      "@sentry/react-native",
      "expo-font"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.actguidance.app",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "ACT sends pilot reminders for capture review and training follow-up.",
        "NSCameraUsageDescription": "ACT uses the camera to record approved HVAC job moments for internal training.",
        "NSMicrophoneUsageDescription": "ACT uses the microphone to capture the senior tech's explanation during approved job recordings.",
        "NSPhotoLibraryUsageDescription": "ACT can attach approved job photos to training cards when you choose them."
      }
    },
    "android": {
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#EA580C"
      },
      "package": "com.actguidance.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "3d481b40-6481-4b5a-8f3a-81729fc92cc9"
      }
    },
    "owner": "evode01"
  }
}
