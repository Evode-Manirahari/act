{
  "expo": {
    "name": "Actober",
    "slug": "actober",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A0A",
    "plugins": [
      "expo-camera",
      "expo-av",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "actober",
          "organization": "actober"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.actober.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.actober.app"
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
